    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-4 columns-2 mx-6">
    <li>Learning capacity</li>
    <li>Self-taught person</li>
    <li>Innovation</li>
    <li>Creativity</li>
    <li>Dynamism.</li>
    <li>Availability</li>
