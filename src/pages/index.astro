---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const last_posts = posts.slice(0, 3);
---

<BaseLayout>

    <div class="pb-12 mt-5">
      <div class="text-xl py-1">Hello there 👋</div>
      <div class="text-5xl font-bold">I'm Alejandro Miguel</div>
      <div class="text-3xl py-3 font-bold">Information Professional, Systems Administrator and Junior Developer in ASP.NET</div>
      <div class="py-2">
        <text class="text-lg">
          ¡Hola y bienvenido a mi perfil web! Soy un apasionado desarrollador y administrador de sistemas con conocimientos en informática y tecnología de la información. Con más de X años de experiencia en el campo, he trabajado en varios proyectos emocionantes y he adquirido habilidades valiosas a lo largo del camino.

          He trabajado en una variedad de lenguajes de programación y también tengo una amplia experiencia en administración y configuración de servidores y redes. Me enorgullece mantenerme actualizado en las últimas tendencias tecnológicas y siempre estoy buscando aprender nuevas habilidades y técnicas para mejorar mi trabajo.
         
          En mi tiempo libre, disfruto creando proyectos personales y experimentando con nuevas tecnologías. Si está interesado en trabajar juntos o en saber más sobre mi experiencia y habilidades, no dude en ponerse en contacto conmigo. ¡Estoy emocionado de conocer a nuevos colegas y desafíos emocionantes en el futuro!
          </text
        >
      </div>
      <div class="mt-8">
        <a class="btn" href="https://twitter.com/MiguelLafaurie" target="_blank"> Let's connect!</a>
        <!-- <a href="https://github.com/manuelernestog/astro-modern-personal-website" target="_blank" class="btn btn-outline ml-5"> Get This template</a> -->
      </div>
    </div>

    <div>
      <div class="text-3xl w-full font-bold mb-2">My last projects {"</>"}</div>
    </div>

    <HorizontalCard
      title="Demo Project 1"
      img="/post_img.webp"
      desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
      url="#"
      badge="NEW"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
    title="Demo Project 2"
    img="/post_img.webp"
    desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    url="#"
  />
    <div class="divider my-0"></div>
    <HorizontalCard
    title="Demo Project 3"
    img="/post_img.webp"
    desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    url="#"
    badge="FOSS"
  />


    <div>
      <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
    </div>

    {
      last_posts.map((post) => (
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.slug}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0"></div>
      ))
    }

</BaseLayout>
